# ─── Production site URL (SEO) ───────────────────────────────
# Used for canonical URLs, Open Graph, sitemap.xml, robots.txt, and JSON-LD.
# Set to your live domain before launch (no trailing slash).
# Falls back to https://example.com when empty (safe for local dev).
NEXT_PUBLIC_SITE_URL=

# ─── Analytics pixel IDs (optional in dev) ───────────────────
# Leave empty until production — third-party scripts will not load.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
